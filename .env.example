# ─── Application ──────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
POSTGRES_USER=copytrader
POSTGRES_PASSWORD=changeme
POSTGRES_DB=copytrader
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://copytrader:changeme@postgres:5432/copytrader

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Polymarket (REST) ────────────────────────────────────────────────────
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com

# ─── Polymarket (WebSocket) ───────────────────────────────────────────────
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws

# ─── The Graph / Goldsky Subgraphs ───────────────────────────────────────
# Orderbook subgraph — OrderFilledEvent (trade history + scoring)
SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/orderbook-subgraph/0.0.1/gn
# PnL subgraph — UserPosition (leaderboard discovery)
SUBGRAPH_PNL_URL=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/pnl-subgraph/0.0.14/gn
# SUBGRAPH_API_KEY=  # if using paid plan

# ─── On-chain (Fase 4 — paper trading não usa) ────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
# WALLET_PRIVATE_KEY=  # NEVER commit; only set in production .env (not .env.example)
# WALLET_ADDRESS=

# ─── Trading config ───────────────────────────────────────────────────────
EXECUTION_MODE=paper           # paper | live
INITIAL_CAPITAL_USD=1000
MAX_PCT_PER_TRADE=0.02         # 2%
MAX_DRAWDOWN_DAILY=0.05        # 5% — kill switch
MAX_OPEN_POSITIONS=10

# ─── API auth (single-user, Fase 2) ───────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme

# ─── Optional alerting ────────────────────────────────────────────────────
# DISCORD_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Fase 4: Kelly position sizing ───────────────────────────────────────
KELLY_FRACTION=0.25             # fraction of full Kelly (0.25 = conservative)
KELLY_MIN_PCT=0.005             # minimum 0.5% per trade
KELLY_MAX_PCT=0.05              # maximum 5% per trade

# ─── Fase 4: Circuit breaker ──────────────────────────────────────────────
CIRCUIT_BREAKER_MAX_CONSECUTIVE=3   # consecutive losses before pause
CIRCUIT_BREAKER_SIGMA=2.0           # std-dev threshold for "bad" loss

# ─── Fase 4: Reconciliation (live mode only) ──────────────────────────────
RECONCILIATION_INTERVAL_SECONDS=300  # 5 min between on-chain checks

# ─── Fase 4: Daily allocation cap ─────────────────────────────────────────
MAX_DAILY_ALLOCATION_USD=0      # 0 = no cap; set e.g. 500 for $500/day limit
